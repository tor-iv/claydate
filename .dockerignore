# Dependencies — reinstalled fresh in Docker
node_modules

# Build output — built inside Docker
.next

# Git history — not needed in image
.git
.gitignore

# Local data — persisted via Docker volume in production
data

# Secrets and local env files — injected via Docker env vars
.env
.env.*
.env.local
.env.production.local

# Test/tooling artifacts
.playwright-mcp
coverage
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# macOS cruft
.DS_Store
