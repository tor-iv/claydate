# Caddy gets Let's Encrypt certs for claydate.nyc automatically.
# The explicit http://claydate.nyc redirect guarantees the domain is never
# served in plaintext; the bare-IP catch-all answers health checks only and
# never proxies app routes (so credentials can't transit plain HTTP).
claydate.nyc {
	encode gzip
	reverse_proxy app:3000
}

# www → apex (works whether or not the www CNAME exists)
www.claydate.nyc {
	redir https://claydate.nyc{uri} permanent
}

http://claydate.nyc http://www.claydate.nyc {
	redir https://claydate.nyc{uri} permanent
}

http:// {
	respond /healthz "ok" 200
	respond "Use https://claydate.nyc" 200
}
